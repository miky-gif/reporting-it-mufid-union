# === Configuration MUFID UNION (backend Node.js) ===
# Copiez ce fichier en « .env » puis adaptez les valeurs.

# Port du serveur API
PORT=8000

# Connexion base de données (URL Sequelize). La base est créée automatiquement
# au démarrage si elle n'existe pas.
# MariaDB / MySQL — root SANS mot de passe (XAMPP, Laragon, WAMP par défaut) :
DATABASE_URL=mysql://root@127.0.0.1:3306/mufid_activites
# Avec un mot de passe : mysql://root:VOTRE_MDP@127.0.0.1:3306/mufid_activites

# Sécurité JWT — REMPLACEZ cette clé en production
JWT_SECRET=change-moi-avec-une-cle-longue-et-aleatoire-please
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — origines autorisées (frontend local), séparées par des virgules
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Mot de passe attribué à tous les comptes de démonstration lors du seeding
SEED_PASSWORD=Mufid2026!

# --- E-mail (OPTIONNEL) ---
# Laissez SMTP_HOST vide pour désactiver l'envoi réel : les e-mails de notification
# seront alors simplement journalisés dans la console (la notif plateforme fonctionne).
# Exemple Gmail : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=vous@gmail.com,
# SMTP_PASS=mot_de_passe_application
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=MUFID UNION <no-reply@mufidunion.cm>
